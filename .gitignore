# =============================================
# Semi-Supervised DeepSDF — .gitignore
# =============================================

# ── Data (never commit raw or preprocessed data) ──
data/
shapenet/
thingi10k/
*.npz
*.npy
*.h5
*.hdf5

# ── Checkpoints (large binary files) ──
experiments/*/seed*/checkpoints/
experiments/*/seed*/checkpoint_epoch_*.pth
# Keep only best weights for reference (optional: remove this line to ignore all)
# experiments/*/seed*/best_model.pth

# ── Results JSON (generated by evaluate.py) ──
# Comment this out if you want to commit final results
# experiments/*/seed*/results.json
# Legacy timestamped snapshots — superseded by results_rerun_fixed_eval.json
experiments/*/seed*/results_legacy_*.json

# ── Logs ──
logs/
*.out
*.err
slurm-*.out

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual env / Conda ──
.venv/
venv/
env/
.conda/
*.conda

# ── Jupyter ──
.ipynb_checkpoints/
*.ipynb

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── OMC (oh-my-claudecode plugin state) ──
.omc/

# ── Compact backups ──
.compact-backups/
.compact-backups/*
.compact-backups/**/*
.compact-backups/**/**/*
.compact-backups/**/**/**/*
.compact-backups/**/**/**/**/*
.compact-backups/**/**/**/**/**/*
.compact-backups/**/**/**/**/**/**/*
.compact-backups/**/**/**/**/**/**/**/*

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── Figures (generated, large) ──
figures/*.png
figures/*.pdf
figures/mesh_comparison_grid/
# Keep source scripts
!figures/.gitkeep

# ── TC2 backup (local only) ──
tc2_backup/

# ── Temporary / debug files ──
tmp/
temp/
debug/
*.tmp
core.*
*.ko.md

# ── WandB / MLflow (if used) ──
wandb/
mlruns/
.mlflow/

# ── SLURM job arrays temp ──
job_registry_lock.tmp

report/figures/**/*

# ── Claude Code runtime state ──
.claude/scheduled_tasks.lock

# ── Archives / tarballs (build artifacts, backups) ──
*.tar.gz
*.tgz
*.tar
*.zip

# ── 3D mesh files (large, regeneratable) ──
*.obj
